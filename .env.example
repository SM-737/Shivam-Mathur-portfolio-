# ──────────────────────────────────────────────────────────────────────────────
# Portfolio — Environment Variables
# Copy this file to .env.local and fill in the values for local development.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Site URL ──────────────────────────────────────────────────────────────────
# Base URL of the deployed site (no trailing slash). Used for sitemap & OG tags.
NEXT_PUBLIC_SITE_URL=https://shivammathur.dev

# ── Contact Form — Email Provider ─────────────────────────────────────────────
# Configure ONE of the following providers to enable real email delivery.
# If neither is set, messages are logged to the server console (graceful fallback).

# Option 1 — Resend (recommended, free tier: 100 emails/day)
# Sign up at https://resend.com → create an API key → add a verified domain.
RESEND_API_KEY=

# Option 2 — SendGrid
# Sign up at https://sendgrid.com → Settings → API Keys → Create API Key.
SENDGRID_API_KEY=

# ── Contact addresses ─────────────────────────────────────────────────────────
# The address emails are sent FROM (must be a verified sender in your provider).
CONTACT_FROM_EMAIL=portfolio@shivammathur.dev

# The address that receives contact form submissions.
CONTACT_TO_EMAIL=sm0181196@gmail.com
